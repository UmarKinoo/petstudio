{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/footer.json",
  "title": "Pet Studio widget: footer",
  "description": "API payload shape \u2014 maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "contact_heading": {
      "type": "string"
    },
    "contact_link": {
      "$ref": "_common.json#/$defs/link"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "logo": {
      "$ref": "_common.json#/$defs/media"
    },
    "tagline": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "hours_heading": {
      "type": "string"
    },
    "hours_text": {
      "type": "string"
    },
    "privacy_label": {
      "type": "string"
    },
    "privacy_link": {
      "$ref": "_common.json#/$defs/link"
    },
    "copyright": {
      "type": "string"
    }
  }
