{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/header.json",
  "title": "Pet Studio widget: header",
  "description": "API payload shape \u2014 maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "logo_default": {
      "$ref": "_common.json#/$defs/media"
    },
    "logo_inverse": {
      "$ref": "_common.json#/$defs/media"
    },
    "logo_link": {
      "$ref": "_common.json#/$defs/link"
    },
    "navigation": {
      "type": "array",
      "items": {
        "$ref": "_common.json#/$defs/nav_item"
      }
    },
    "social_items": {
      "type": "array",
      "items": {
        "$ref": "_common.json#/$defs/social_item"
      }
    },
    "enable_sticky": {
      "type": "boolean"
    },
    "enable_transparent": {
      "type": "boolean"
    },
    "show_book_now": {
      "type": "boolean"
    },
    "book_now_label": {
      "type": "string"
    },
    "book_now_link": {
      "$ref": "_common.json#/$defs/link"
    }
  }
}