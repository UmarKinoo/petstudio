{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/services-cards.json",
  "title": "Pet Studio widget: services-cards",
  "description": "API payload shape \u2014 maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "heading": {
      "type": "string"
    },
    "heading_accent": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "items": {
        "$ref": "_common.json#/$defs/service_card"
      }
    }
  }
}