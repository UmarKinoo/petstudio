{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/team-member.json",
  "title": "Pet Studio widget: team-member",
  "description": "API payload shape \u2014 maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "name_line_1": {
      "type": "string"
    },
    "name_accent": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "portrait": {
      "$ref": "_common.json#/$defs/media"
    },
    "show_signature": {
      "type": "boolean"
    },
    "signature_image": {
      "$ref": "_common.json#/$defs/media"
    },
    "reverse_columns": {
      "type": "boolean"
    }
  }
}