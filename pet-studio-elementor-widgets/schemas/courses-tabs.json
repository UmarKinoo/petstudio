{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/courses-tabs.json",
  "title": "Pet Studio widget: courses-tabs",
  "description": "API payload shape \u2014 maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "tabs": {
      "type": "array",
      "items": {
        "$ref": "_common.json#/$defs/course_tab"
      }
    },
    "default_active_tab": {
      "type": "integer",
      "minimum": 0
    }
  }
}