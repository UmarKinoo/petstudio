{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/contact.json",
  "title": "Pet Studio widget: contact",
  "description": "API payload shape — maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "heading": { "type": "string" },
    "subheading": { "type": "string" },
    "phone": { "type": "string" },
    "intro_text": { "type": "string" },
    "academy_heading": { "type": "string" },
    "academy_intro": { "type": "string" },
    "form_shortcode": { "type": "string" },
    "recipient_email": { "type": "string" },
    "email_subject": { "type": "string" },
    "button_text": { "type": "string" },
    "success_message": { "type": "string" },
    "show_enquiry_type": { "type": "boolean" },
    "message_required": { "type": "boolean" },
    "address": { "type": "string" },
    "maps_button_text": { "type": "string" },
    "maps_link": { "$ref": "_common.json#/$defs/link" },
    "sticky_image": { "$ref": "_common.json#/$defs/media" },
    "mobile_image": { "$ref": "_common.json#/$defs/media" },
    "map_lat": { "type": "string" },
    "map_lng": { "type": "string" },
    "map_zoom": { "type": "integer" },
    "map_marker_title": { "type": "string" }
  }
}
