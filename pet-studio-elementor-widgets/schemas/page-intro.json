{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepetstudio.local/schemas/page-intro.json",
  "title": "Pet Studio widget: page-intro",
  "description": "API payload shape \u2014 maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "heading": {
      "type": "string"
    },
    "heading_accent": {
      "type": "string"
    },
    "blockquote": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "show_signature": {
      "type": "boolean"
    },
    "signature_image": {
      "$ref": "_common.json#/$defs/media"
    },
    "badge_image": {
      "$ref": "_common.json#/$defs/media"
    },
    "primary_image": {
      "$ref": "_common.json#/$defs/media"
    },
    "secondary_image": {
      "$ref": "_common.json#/$defs/media"
    }
  }
}