  "$id": "https://thepetstudio.local/schemas/faq.json",
  "title": "Pet Studio widget: faq",
  "description": "API payload shape — maps 1:1 to Elementor widget settings after normalization.",
  "type": "object",
  "properties": {
    "heading": { "type": "string" },
    "heading_accent": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
